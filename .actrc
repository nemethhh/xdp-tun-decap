# act configuration for local GitHub Actions testing
# https://github.com/nektos/act

# Use ubuntu-22.04 image for consistency with CI
-P ubuntu-22.04=catthehacker/ubuntu:act-22.04
-P ubuntu-latest=catthehacker/ubuntu:act-22.04

# Mount Docker socket for integration tests (if needed)
--container-daemon-socket -

# Set default environment variables
--env ACTIONS_RUNTIME_TOKEN=fake-token
--env ACTIONS_CACHE_URL=https://fake-cache.local

# Verbose output
# Uncomment for debugging:
# -v
