# Docker ignore file for linting container

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Documentation (not needed for linting)
*.md
!README.md

# Test files
test_*.py

# Build artifacts
build/
dist/
*.egg-info/

# System files
.DS_Store
Thumbs.db
