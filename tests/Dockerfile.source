# Dockerfile for tunnel source container
FROM ubuntu:25.04

RUN apt-get update && apt-get install -y \
    iproute2 \
    iputils-ping \
    python3 \
    python3-scapy \
    tcpdump \
    && rm -rf /var/lib/apt/lists/*

COPY tests/generate-packets.py /usr/local/bin/generate-packets.py
RUN chmod +x /usr/local/bin/generate-packets.py

WORKDIR /app

CMD ["/bin/bash"]
